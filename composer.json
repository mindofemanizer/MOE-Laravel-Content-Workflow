{
    "name": "moe/laravel-content-workflow",
    "description": "All-in-one content workflow management for Laravel - state machines, scheduling, versioning, approvals, and WYSIWYG editor",
    "type": "library",
    "keywords": [
        "laravel",
        "content",
        "workflow",
        "cms",
        "state-machine",
        "scheduling",
        "versioning",
        "approval",
        "publishable",
        "wysiwyg",
        "editor",
        "tiptap",
        "livewire",
        "moe"
    ],
    "homepage": "https://github.com/mindofemanizer/MOE-Laravel-Content-Workflow",
    "license": "MIT",
    "authors": [
        {
            "name": "MOE (MindOfEmanizer)",
            "email": "your-email@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/console": "^11.0|^12.0|^13.0",
        "nesbot/carbon": "^2.0|^3.0",
        "livewire/livewire": "^3.0"
    },
    "suggest": {
        "moe/laravel-identifiers": "Automatically generate ULID primary keys and document numbers for your content",
        "moe/laravel-image-pipeline": "Preset-driven image pipeline for WYSIWYG editor image uploads and transformations"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "phpstan/phpstan": "^1.0",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "MOE\\ContentWorkflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "MOE\\ContentWorkflow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MOE\\ContentWorkflow\\ContentWorkflowServiceProvider"
            ],
            "aliases": {
                "MoeContent": "MOE\\ContentWorkflow\\Facades\\MoeContent"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse --level=8",
        "phpcs": "vendor/bin/phpcs --standard=PSR12 src/",
        "phpcbf": "vendor/bin/phpcbf --standard=PSR12 src/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
